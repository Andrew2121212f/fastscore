# Marketing API (OAuth2 client_credentials)
API_BASE_URL=https://cpservm.com
API_CLIENT_ID=your_client_id
API_CLIENT_SECRET=your_client_secret
API_REF=your_ref

# NewsData.io — внешний поток спортивных новостей (200 кредитов/день free)
# https://newsdata.io
NEWS_API_KEY=pub_xxxxxxxxxxxxxxxxxx

# Google Sheets — кастомные статьи (CMS для маркетинга)
# ID таблицы из URL: docs.google.com/spreadsheets/d/{ID}/edit
# Таблица должна быть "anyone with link can view".
# См. docs/NEWS_GUIDE.md
NEWS_SHEET_ID=your_sheet_id

# Site URL (used for SEO meta tags)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
